@token = REPLACE_WITH_JWT
@userId = REPLACE_WITH_USER_UUID

### Login
POST  http://localhost:3000/api/auth/login
Content-Type: application/json

{
  "email":"",
  "password":""
}


### Renew token
GET  http://localhost:3000/api/auth/renew
Authorization: Bearer Token


### Register User
POST  http://localhost:3000/api/auth/register
Content-Type: application/json

{
  "name":"",
  "lastname":"",
  "email":"",
  "phone":"",
  "password":"",
  "branchId":"",
  "branchIds":[""],
  "username":"",
  "role":"USER",
  "allowWhatsappAssistant": false
}

### Update User (multi-sucursal)
PUT http://localhost:3000/api/users/{{userId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "",
  "lastname": "",
  "username": "",
  "email": "",
  "phone": "",
  "role": "BRANCH_MANAGER",
  "branchIds": ["", ""],
  "isActive": true,
  "allowWhatsappAssistant": false
}
